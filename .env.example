# Database
DATABASE_URL=postgresql://weebrook:weebrook@localhost:5432/weebrook

# JWT
JWT_SECRET=ginsberg-koseck-ramirez
JWT_EXPIRES_IN=7d

# S3 / MinIO (dev) or AWS S3 (production)
# Dev: uses MinIO running in Docker (credentials match docker-compose.yml)
# Production: set real AWS credentials and remove S3_ENDPOINT
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=weebrook
AWS_SECRET_ACCESS_KEY=weebrook123
S3_BUCKET=weebrook-assets
S3_ENDPOINT=http://localhost:9000

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SES (email)
SES_FROM_EMAIL=noreply@weebrook.app

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@weebrook.app

# App
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
PORT=3001

# GC admin seed account
GC_SEED_EMAIL=admin@weebrook.app
GC_SEED_PASSWORD=changeme

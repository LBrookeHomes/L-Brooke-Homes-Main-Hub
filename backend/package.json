{
  "name": "@weebrook/backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --schema src/prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "seed": "tsx src/prisma/seed/index.ts",
    "seed:demo": "tsx src/prisma/seed/demo.ts",
    "generate": "prisma generate --schema src/prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "dotenv": "^16.4.5",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^5.16.0",
    "prisma": "^5.16.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "twilio": "^5.2.3",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/web-push": "^3.6.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}

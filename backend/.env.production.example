# Copy this to .env on the EC2 instance and fill in real values.
# Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL runs on the same Lightsail instance — localhost connection, no VPC needed.
DATABASE_URL=postgresql://weebrook:CHANGE_THIS_PASSWORD@localhost:5432/weebrook

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_EXPIRES_IN=7d

# ── S3 (uploads bucket) ───────────────────────────────────────────────────────
# Lightsail doesn't support IAM instance roles — use static credentials.
# Create a dedicated IAM user with s3:PutObject / s3:GetObject on weebrook-uploads only.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_IAM_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_IAM_SECRET
S3_BUCKET=weebrook-uploads
# S3_ENDPOINT — leave unset; uses real AWS S3 in production

# ── Twilio (SMS) — leave blank during UAT ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── AWS SES (email) — leave blank during UAT ─────────────────────────────────
SES_FROM_EMAIL=noreply@yourdomain.com

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# Set to your CloudFront URL or custom domain (used for CORS origin)
APP_URL=https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net

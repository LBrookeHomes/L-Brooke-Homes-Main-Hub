# Railway environment variables — set these in the Railway service dashboard,
# not in a file. Listed here for reference.
#
# DATABASE_URL is auto-injected by the Railway PostgreSQL plugin — do not set it manually.

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_SECRET   # openssl rand -base64 48
JWT_EXPIRES_IN=7d

# ── S3 (uploads bucket) ───────────────────────────────────────────────────────
# Railway doesn't have IAM instance roles — use a dedicated IAM user.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_IAM_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_IAM_SECRET
S3_BUCKET=weebrook-uploads

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# ── Twilio (SMS) — leave blank during UAT ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── AWS SES (email) — leave blank during UAT ─────────────────────────────────
SES_FROM_EMAIL=noreply@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is injected automatically by Railway — do not set it here.
# Set APP_URL to your Vercel frontend URL (used for CORS).
APP_URL=https://YOUR_APP.vercel.app
